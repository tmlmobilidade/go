{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"allowJs": false,
		"esModuleInterop": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"moduleDetection": "force",
		"noImplicitOverride": true,
		"noUncheckedIndexedAccess": false,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"strict": false,
		"target": "es2022"
	}
}
