{
	"name": "@tmlmobilidade/sae-plans",
	"private": true,
	"scripts": {
		"build": "turbo build",
		"dev": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev",
		"lint": "turbo lint",
		"rinse": "npx --yes @tmlmobilidade/repo-rinse",
		"start": "turbo start",
		"yalc:tml": "yalc link @tmlmobilidade/connectors @tmlmobilidade/interfaces @tmlmobilidade/lib @tmlmobilidade/utils @tmlmobilidade/types @tmlmobilidade/ui --no-pure"
	},
	"devDependencies": {
		"@carrismetropolitana/eslint": "20250622.1204.50",
		"@dotenv-run/cli": "1.3.6",
		"turbo": "2.5.4",
		"typescript": "5.8.3"
	},
	"packageManager": "npm@11.4.2",
	"engines": {
		"node": ">=18"
	},
	"workspaces": [
		"apps/*"
	]
}
