{
	"name": "@tmlmobilidade/generate-routes",
	"description": "A CLI tool to generate route constants from a monorepo.",
	"version": "1.0.0",
	"author": {
		"email": "iso@tmlmobilidade.pt",
		"name": "TML-ISO"
	},
	"license": "AGPL-3.0-or-later",
	"type": "module",
	"files": [
		"dist"
	],
	"main": "./dist/index.js",
	"bin": {
		"generate-routes": "dist/index.js"
	},
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsc && resolve-tspaths",
		"dev": "tsx watch src/index.ts",
		"lint": "eslint . --fix && tsc --noEmit",
		"lint:fix": "eslint ./src --fix",
		"start": "tsc && resolve-tspaths && node dist/index.js"
	},
	"devDependencies": {
		"@tmlmobilidade/tsconfig": "*",
		"@types/node": "25.9.1",
		"resolve-tspaths": "0.8.23",
		"tsx": "4.22.4",
		"typescript": "5.9.3"
	}
}
