{
	"$schema": "https://turbo.build/schema.json",
	"envMode": "loose",
	"globalEnv": ["NODE_ENV"],
	"tasks": {
		"build": {
			"dependsOn": [
				"^build"
			],
			"outputs": [
				"dist/**"
			]
		},
		"clean": {
			"cache": false
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"lint": {
			"dependsOn": [
				"^lint"
			]
		},
		"lint:fix": {
			"dependsOn": [
				"^lint:fix"
			]
		},
		"start": {
			"dependsOn": [
				"^build",
				"^start"
			],
			"outputs": [
				"dist/**"
			]
		}
	},
	"ui": "tui"
}
