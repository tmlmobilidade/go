		"@go/utils-files": "*",
		"@go/utils-strings": "*",
		"@tmlmobilidade/tsconfig": "*",
		"bcryptjs": "3.0.2",
		"oci-common": "2.119.1",
		"oci-objectstorage": "2.119.1",
		"zod": "3.25.76"
	},
	"devDependencies": {
		"@carrismetropolitana/eslint": "20250622.1204.50",
