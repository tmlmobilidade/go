# Copy this file to .devcontainer/tunnels.local.env and fill values.
# Example:
# cp .devcontainer/tunnels.example.env .devcontainer/tunnels.local.env

# SSH bastion or VM endpoint
SSH_HOST=
SSH_USER=
SSH_PORT=22
SSH_KEY_PATH=

# Local bind settings (inside devcontainer)
LOCAL_BIND_ADDRESS=127.0.0.1

# Tunnel mappings as comma-separated local:remoteHost:remotePort
# Example for MongoDB and ClickHouse:
# TUNNELS=27017:127.0.0.1:27017,8123:127.0.0.1:8123,9000:127.0.0.1:9000
TUNNELS=
