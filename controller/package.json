{
	"name": "@tmlmobilidade/sae-controller",
	"private": true,
	"scripts": {
		"build": "turbo build",
		"dev": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev",
		"dev:sams-examiner": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@tmlmobilidade/sae-controller-sams-examiner",
		"dev:sams-feeder": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@tmlmobilidade/sae-controller-sams-feeder",
		"lint": "turbo lint",
		"purge": "sh purge.sh"
	},
	"devDependencies": {
		"@carrismetropolitana/eslint": "20250418.42.41",
		"@dotenv-run/cli": "1.3.6",
		"turbo": "2.5.4",
		"typescript": "5.8.3"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"packageManager": "npm@11.4.2",
	"engines": {
		"node": ">=18"
	}
}
