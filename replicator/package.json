{
	"name": "@tmlmobilidade/sae-replicator",
	"private": true,
	"scripts": {
		"build": "turbo build",
		"build:packages": "turbo build --filter=@tmlmobilidade/sae-replicator-pckg-*",
		"dev:enrich": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@tmlmobilidade/sae-replicator-enrich",
		"dev:stream": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@tmlmobilidade/sae-replicator-stream",
		"dev:sync-apex": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@tmlmobilidade/sae-replicator-sync-apex-*",
		"dev:sync-apex-locations": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@tmlmobilidade/sae-replicator-sync-apex-locations",
		"dev:sync-apex-on-board-refunds": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@tmlmobilidade/sae-replicator-sync-apex-on-board-refunds",
		"dev:sync-apex-on-board-sales": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@tmlmobilidade/sae-replicator-sync-apex-on-board-sales",
		"dev:sync-apex-validations": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@tmlmobilidade/sae-replicator-sync-apex-validations",
		"helper:dump-vehicle-events": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@tmlmobilidade/sae-replicator-helpers-dump-vehicle-events",
		"lint": "turbo lint",
		"rinse": "npx --yes @tmlmobilidade/repo-rinse",
		"start": "turbo start"
	},
	"devDependencies": {
		"@carrismetropolitana/eslint": "20250622.1204.50",
		"@dotenv-run/cli": "1.3.6",
		"turbo": "2.5.4",
		"typescript": "5.8.3"
	},
	"workspaces": [
		"apps/*",
		"helpers/*",
		"packages/*"
	],
	"packageManager": "npm@11.4.2",
	"engines": {
		"node": ">=18"
	}
}
