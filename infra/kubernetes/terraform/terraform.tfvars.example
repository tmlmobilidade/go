# # #
# terraform.tfvars.example
#
# Copy this file to terraform.tfvars and fill in the values.
# IMPORTANT: Never commit terraform.tfvars to version control
#            (it contains secrets and is listed in .gitignore).


# -----------------------------------------------------------------------
# OCI AUTHENTICATION
# Generated in OCI Console > Profile > API Keys > Add API Key
# -----------------------------------------------------------------------

tenancy_ocid        = "ocid1.tenancy.oc1..your_tenancy_ocid_here"
user_ocid           = "ocid1.user.oc1..your_user_ocid_here"
fingerprint         = "xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx"
private_key_path    = "~/.oci/oci_api_key.pem"
ssh_public_key_path = "~/.ssh/id_rsa.pub"


# -----------------------------------------------------------------------
# EXISTING NETWORKING — obtain from the networking team or OCI Console
# OCI Console > Networking > Virtual Cloud Networks > <your VCN> > Subnets
# -----------------------------------------------------------------------

vcn_id            = "ocid1.vcn.oc1.eu-frankfurt-1.your_vcn_ocid_here"
public_subnet_id  = "ocid1.subnet.oc1.eu-frankfurt-1.your_public_subnet_ocid_here"
private_subnet_id = "ocid1.subnet.oc1.eu-frankfurt-1.your_private_subnet_ocid_here"


# -----------------------------------------------------------------------
# CLUSTER SETTINGS
# -----------------------------------------------------------------------

# To list valid Kubernetes versions:
#   oci ce cluster-options get --cluster-option-id all --query 'data.kubernetesVersions'
kubernetes_version = "v1.31.1"


# -----------------------------------------------------------------------
# NODE POOL — PoC defaults (1 node, minimal resources)
# Increase node_count and node_ocpus for production.
# -----------------------------------------------------------------------

node_count         = 1
node_ocpus         = 2
node_memory_in_gbs = 8


# -----------------------------------------------------------------------
# PROXY VM
# worker_node_ips: get from `kubectl get nodes -o wide` after node pool is active.
# -----------------------------------------------------------------------

worker_node_ips = ["10.x.x.x"]


# -----------------------------------------------------------------------
# OPTIONAL OVERRIDES (defaults are defined in variables.tf)
# -----------------------------------------------------------------------

# project_name        = "iso-go"
# region              = "eu-frankfurt-1"
# compartment_ocid    = "ocid1.compartment.oc1..aaaaaaaaqwnoahpbcxhsogpszdixlv4jnrnujst7qxyar6536oeptpwjtkna"
# availability_domain = "LUDo:EU-FRANKFURT-1-AD-1"
# node_shape          = "VM.Standard.E4.Flex"
