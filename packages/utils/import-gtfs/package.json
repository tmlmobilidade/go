	"repository": {
		"type": "git",
		"url": "git+https://github.com/tmlmobilidade/services.git"
	},
	"keywords": [
		"public transit",
		"tml",
		"transportes metropolitanos de lisboa",
		"services"
	],
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"files": [
