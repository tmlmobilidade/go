{
	"name": "@tmlmobilidade/sae-plans",
	"private": true,
	"scripts": {
		"build": "turbo build",
		"dev": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev",
		"dev:cleaner": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@tmlmobilidade/sae-plans-cleaner",
		"dev:export-drt": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@tmlmobilidade/sae-plans-export-drt",
		"dev:export-posters": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@tmlmobilidade/sae-plans-export-posters",
		"dev:production": "dotenv-run -f ./environments/production/secrets/.env -- turbo dev",
		"dev:staging": "dotenv-run -f ./environments/staging/secrets/.env -- turbo dev",
		"dev:ui": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@tmlmobilidade/sae-plans-frontend --filter=@tmlmobilidade/sae-plans-api",
		"lint": "turbo lint",
		"rinse": "npx --yes @tmlmobilidade/repo-rinse",
		"start": "turbo start"
	},
	"devDependencies": {
		"@carrismetropolitana/eslint": "20250622.1204.50",
		"@dotenv-run/cli": "1.3.6",
		"turbo": "2.5.8",
		"typescript": "5.9.3"
	},
	"packageManager": "npm@11.6.2",
	"engines": {
		"node": ">=18"
	},
	"workspaces": [
		"apps/*"
	]
}
