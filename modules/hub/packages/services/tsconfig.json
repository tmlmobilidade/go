{
	"extends": "@tmlmobilidade/tsconfig/lib.json",
	"compilerOptions": {
		"allowJs": true,
		"outDir": "dist",
		"paths": {
			"@/*": ["./src/*"]
		},
		"rootDir": "src",
		"strictNullChecks": true
	},
	"include": ["src/**/*.ts", "src/**/*.js"],
	"exclude": ["node_modules", "dist", "src/redis.service.ts"]
}
