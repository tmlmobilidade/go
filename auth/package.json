{
	"name": "@tmlmobilidade/sae-auth",
	"version": "1.0.0",
	"keywords": [],
	"main": "index.js",
	"scripts": {
		"build": "turbo build",
		"dev": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev",
		"dev:exporter:prod": "dotenv-run -f ./environments/production/secrets/.env -- turbo dev --filter=@tmlmobilidade/sae-auth-file-exporter",
		"dev:production": "dotenv-run -f ./environments/production/secrets/.env -- turbo dev",
		"lint": "turbo lint",
		"rinse": "npx --yes @tmlmobilidade/repo-rinse",
		"start": "turbo start",
		"yalc": "yalc link @tmlmobilidade/connectors @tmlmobilidade/interfaces @tmlmobilidade/lib @tmlmobilidade/utils @tmlmobilidade/types @tmlmobilidade/ui --no-pure"
	},
	"devDependencies": {
		"@carrismetropolitana/eslint": "20250622.1204.50",
		"@dotenv-run/cli": "1.3.6",
		"turbo": "2.6.0",
		"typescript": "5.9.3"
	},
	"packageManager": "npm@11.6.2",
	"workspaces": [
		"apps/*"
	]
}
