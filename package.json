{
	"name": "go",
	"author": "João de Vasconcelos & Jusi Monteiro",
	"license": "AGPL-3.0-or-later",
	"main": "index.js",
	"scripts": {
		"build": "turbo build",
		"build:packages": "turbo build --filter=./packages/**/*",
		"build:types": "turbo build --filter=@tmlmobilidade/go-types",
		"dev": "turbo dev",
		"dev:packages": "turbo dev --filter=./packages/**/*",
		"dev:types": "turbo dev --filter=@tmlmobilidade/go-types",
		"lint": "turbo lint",
		"lint:fix": "turbo lint:fix",
		"lint:fix:packages": "turbo lint:fix --filter=./packages/*",
		"lint:packages": "turbo lint --filter=./packages/*"
	},
	"devDependencies": {
		"@carrismetropolitana/eslint": "20250622.1204.50",
		"tsup": "^8.5.0",
		"tsx": "4.20.6",
		"turbo": "2.5.8"
	},
	"packageManager": "npm@11.6.2",
	"workspaces": [
		"modules/**/*",
		"packages/**/*",
		"cli/*"
	]
}
