{
	"name": "@tmlmobilidade/connectors-fastify",
	"version": "1.0.0",
	"author": {
		"email": "iso@tmlmobilidade.com",
		"name": "TML-ISO"
	},
	"license": "AGPL-3.0-or-later",
	"homepage": "https://github.com/tmlmobilidade/go#readme",
	"bugs": {
		"url": "https://github.com/tmlmobilidade/go/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tmlmobilidade/go.git"
	},
	"keywords": [
		"public transit",
		"tml",
		"transportes metropolitanos de lisboa",
		"go"
	],
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"files": [
		"dist/"
	],
	"main": "index.ts",
	"types": "index.ts",
	"scripts": {
		"build": "tsc && resolve-tspaths",
		"watch": "tsc-watch --onSuccess 'resolve-tspaths'",
		"lint": "eslint . && tsc --noEmit",
		"lint:fix": "eslint . --fix"
	},
	"dependencies": {
		"@fastify/cookie": "11.0.2",
		"@fastify/cors": "11.1.0",
		"@fastify/websocket": "11.2.0",
		"@tmlmobilidade/consts": "*",
		"@tmlmobilidade/dates": "*",
		"@tmlmobilidade/utils": "*",
		"fastify": "5.6.1"
	},
	"devDependencies": {
		"@tmlmobilidade/tsconfig": "*",
		"@tmlmobilidade/types": "*",
		"@types/node": "24.10.0",
		"resolve-tspaths": "0.8.23",
		"tsc-watch": "7.2.0",
		"typescript": "5.9.3"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	}
}
