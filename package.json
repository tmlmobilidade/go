{
	"name": "@tmlmobilidade/go",
	"author": {
		"email": "iso@tmlmobilidade.pt",
		"name": "TML-ISO"
	},
	"license": "AGPL-3.0-or-later",
	"main": "index.js",
	"scripts": {
		"build": "turbo build",
		"build:packages": "turbo build --filter=./packages/**/*",
		"build:types": "turbo build --filter=@tmlmobilidade/types",
		"dev:alerts": "dotenv-run -f ./modules/alerts/environments/development/secrets/.env -- turbo run dev --filter=@tmlmobilidade/go-alerts-*",
		"dev:auth": "dotenv-run -f ./modules/auth/environments/development/secrets/.env -- turbo run dev --filter=@tmlmobilidade/go-auth-*",
		"dev:controller": "dotenv-run -f ./modules/controller/environments/development/secrets/.env -- turbo run dev --filter=@tmlmobilidade/go-controller-*",
		"dev:locations": "dotenv-run -f ./modules/locations/environments/development/secrets/.env -- turbo run dev --filter=@tmlmobilidade/go-locations-*",
		"dev:performance": "dotenv-run -f ./modules/performance/environments/development/secrets/.env -- turbo run dev --filter=@tmlmobilidade/go-performance-*",
		"dev:plans": "dotenv-run -f ./modules/plans/environments/development/secrets/.env -- turbo run dev --filter=@tmlmobilidade/go-plans-*",
		"dev:replicator": "dotenv-run -f ./modules/replicator/environments/development/secrets/.env -- turbo run dev --filter=@tmlmobilidade/go-replicator-*",
		"dev:stops": "dotenv-run -f ./modules/stops/environments/development/secrets/.env -- turbo run dev --filter=@tmlmobilidade/go-stops-*",
		"lint": "turbo lint",
		"lint:fix": "turbo lint:fix",
		"rinse": "npx --yes @tmlmobilidade/repo-rinse",
		"watch:packages": "turbo run build --filter=./packages/**/* && turbo run watch --filter=./packages/**/*"
	},
	"devDependencies": {
		"@carrismetropolitana/eslint": "20250622.1204.50",
		"@dotenv-run/cli": "1.3.6",
		"turbo": "2.6.0"
	},
	"packageManager": "npm@11.6.2",
	"workspaces": [
		"!**/.next",
		"modules/**/*",
		"packages/**/*",
		"cli/*"
	]
}
