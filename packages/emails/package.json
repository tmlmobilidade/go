	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tmlmobilidade/services.git"
	},
	"keywords": [
		"public transit",
		"tml",
		"transportes metropolitanos de lisboa",
		"services"
	],
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"files": ["dist"],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsc && resolve-tspaths",
		"dev2": "email dev -p 3001 --dir ./src/emails",
		"export": "email export --dir ./src/emails",
		"lint": "eslint ./src/ && tsc --noEmit",
		"watch": "tsc-watch --onSuccess 'resolve-tspaths'"
	},
	"dependencies": {
		"@react-email/components": "1.0.6",
		"@tmlmobilidade/consts": "*",
		"@tmlmobilidade/dates": "*",
		"@tmlmobilidade/types": "*",
		"@tmlmobilidade/utils": "*",
		"@types/nodemailer": "7.0.9",
		"browserslist": "4.28.1",
		"nodemailer": "7.0.13",
		"react": "19.2.4",
		"react-email": "5.2.5"
	},
	"devDependencies": {
		"@react-email/preview-server": "5.2.5",
		"@tmlmobilidade/tsconfig": "*",
		"@types/node": "25.2.0",
		"resolve-tspaths": "0.8.23",
		"tsc-watch": "7.2.0",
		"typescript": "5.9.3"
	}
