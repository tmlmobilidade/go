{
	"name": "@tmlmobilidade/export-data",
	"description": "A CLI tool to export data from GO.",
	"version": "1.0.0",
	"author": {
		"email": "iso@tmlmobilidade.pt",
		"name": "TML-ISO"
	},
	"license": "AGPL-3.0-or-later",
	"type": "module",
	"files": [
		"dist"
	],
	"main": "./dist/index.js",
	"bin": {
		"export-data": "dist/index.js"
	},
	"types": "./dist/index.d.ts",
	"scripts": {
