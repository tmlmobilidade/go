{
	"extends": "@tmlmobilidade/tsconfig/nextjs.json",
	"compilerOptions": {
		"paths": {
			"@/*": [
				"./src/*"
			]
		},
		"plugins": [
			{
				"name": "next"
			}
		],
		"rootDir": ".",
		"types": ["node"]
	},
	"include": [
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		".next/types/**/*.ts"
, "src/components/StopContainer/MapContainer/Header", "src/components/StopContainer/MapContainer/Mapper"	],
	"exclude": [
		"node_modules"
	]
}
