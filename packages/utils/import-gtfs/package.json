		"lint": "eslint ./src/ && tsc --noEmit"
	},
	"dependencies": {
		"@tmlmobilidade/connectors": "*",
		"@tmlmobilidade/go-utils-logger": "*",
		"@tmlmobilidade/go-utils-timer": "*",
