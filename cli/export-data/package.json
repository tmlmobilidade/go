		"@tmlmobilidade/logger": "*",
		"@tmlmobilidade/timer": "*",
		"@tmlmobilidade/utils": "*",
		"@tmlmobilidade/writers": "*",
		"commander": "14.0.2",
		"csv-parse": "6.1.0",
		"extract-zip": "2.0.1",
		"gtfs-types": "5.1.0"
	},
	"devDependencies": {
		"@tmlmobilidade/tsconfig": "*",
		"@tmlmobilidade/types": "*",
		"@types/node": "25.0.3",
		"resolve-tspaths": "0.8.23",
		"tsx": "4.21.0",
		"typescript": "5.9.3"
	}
}
