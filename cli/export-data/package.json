{
	"name": "@tmlmobilidade/export-data",
	"description": "CLI tool to export data from GO.",
	"version": "1.0.0",
	"author": {
		"email": "iso@tmlmobilidade.pt",
		"name": "TML-ISO"
	},
	"license": "AGPL-3.0-or-later",
	"keywords": [
		"navegante",
		"tmlmobilidade",
		"public-transit",
		"carrismetropolitana"
	],
	"type": "module",
	"files": [
		"dist",
		"template",
		"README.md",
		"LICENSE",
		"CHANGELOG.md",
		"package.json"
	],
	"main": "./dist/index.js",
	"exports": {
		".": "./dist/index.js"
	},
	"bin": {
		"export-data": "./dist/index.js"
	},
	"scripts": {
		"build": "tsc && resolve-tspaths",
		"dev": "tsx src/index.ts",
		"lint": "eslint . --fix && tsc --noEmit",
		"lint:fix": "eslint . --fix"
	},
	"dependencies": {
		"@clack/prompts": "1.6.0",
		"@tmlmobilidade/consts": "*",
		"@tmlmobilidade/dates": "*",
		"@tmlmobilidade/go-types-apex": "*",
		"@tmlmobilidade/go-types-shared": "*",
		"@tmlmobilidade/interfaces": "*",
		"@tmlmobilidade/logger": "*",
		"@tmlmobilidade/strings": "*",
		"@tmlmobilidade/timer": "*",
		"@tmlmobilidade/types": "*",
		"@tmlmobilidade/writers": "*",
		"exceljs": "^4.4.0"
	},
	"devDependencies": {
		"@tmlmobilidade/tsconfig": "*",
		"@types/node": "26.0.0",
		"resolve-tspaths": "0.8.23",
		"typescript": "6.0.3"
	}
}
