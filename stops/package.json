{
	"name": "@tmlmobilidade/sae-stops",
	"private": true,
	"scripts": {
		"build": "turbo build",
		"clean": "npx @tmlmobilidade/repo-rinse",
		"dev": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev",
		"dev:parser": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@tmlmobilidade/sae-stops-parser",
		"lint": "turbo lint",
		"start": "turbo start"
	},
	"devDependencies": {
		"@carrismetropolitana/eslint": "20250622.1204.50",
		"@tmlmobilidade/tsconfig": "20250725.1012.48",
		"dotenv-cli": "9.0.0",
		"prettier": "3.6.2",
		"turbo": "2.5.5",
		"typescript": "5.8.3"
	},
	"packageManager": "npm@11.5.1",
	"engines": {
		"node": ">=18"
	},
	"workspaces": [
		"apps/*"
	],
	"dependencies": {
		"@carrismetropolitana/api-types": "^20250717.940.43",
		"@tmlmobilidade/types": "^20250725.1012.48",
		"@tmlmobilidade/ui": "^20250725.1012.48",
		"react": "^19.1.0"
	}
