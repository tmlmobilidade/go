		"@tmlmobilidade/utils": "*",
		"csv-parse": "6.1.0"
	},
	"devDependencies": {
		"@carrismetropolitana/eslint": "20250622.1204.50",
		"@tmlmobilidade/lib": "*",
		"@tmlmobilidade/tsconfig": "*",
		"@tmlmobilidade/go-types": "*",
