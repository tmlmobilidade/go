{
	"name": "@tmlmobilidade/sae-locations",
	"private": true,
	"scripts": {
		"build": "turbo build",
		"seed:test": "dotenv-run -f ./environments/development/secrets/.env -- tsx apps/sync-locations/src/test.ts",
		"seed": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@tmlmobilidade/sae-sync-locations",
		"rinse": "npx @tmlmobilidade/repo-rinse",
		"dev": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=!@tmlmobilidade/sae-sync-locations",
		"lint": "turbo lint",
		"start": "turbo start"
	},
	"devDependencies": {
		"@carrismetropolitana/eslint": "20250622.1204.50",
		"@dotenv-run/cli": "1.3.6",
		"turbo": "2.5.8",
		"typescript": "5.9.3"
	},
	"packageManager": "npm@11.6.2",
	"engines": {
		"node": ">=18"
	},
	"workspaces": [
		"apps/*"
	]
}
