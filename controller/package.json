{
	"name": "@tmlmobilidade/sae-controller",
	"private": true,
	"scripts": {
		"build": "turbo build",
		"clean": "sh cleanup.sh",
		"dev": "turbo dev",
		"dev:bridge": "turbo dev --filter=@tmlmobilidade/sae-controller-bridge",
		"dev:cleaner": "turbo dev --filter=@tmlmobilidade/sae-controller-cleaner",
		"dev:control": "turbo dev --filter=@tmlmobilidade/sae-controller-control",
		"dev:explorer": "turbo dev --filter=@tmlmobilidade/sae-controller-explorer-server --filter=@tmlmobilidade/sae-controller-explorer-frontend",
		"dev:explorer-frontend": "turbo dev --filter=@tmlmobilidade/sae-controller-explorer-frontend",
		"dev:explorer-server": "turbo dev --filter=@tmlmobilidade/sae-controller-explorer-server",
		"dev:feeder": "turbo dev --filter=@tmlmobilidade/sae-controller-feeder",
		"dev:monitor": "turbo dev --filter=@tmlmobilidade/sae-controller-monitor-coordinator --filter=@tmlmobilidade/sae-controller-monitor-worker",
		"dev:monitor-coordinator": "turbo dev --filter=@tmlmobilidade/sae-controller-monitor-coordinator",
		"dev:monitor-worker": "turbo dev --filter=@tmlmobilidade/sae-controller-monitor-worker",
		"dev:stream": "turbo dev --filter=@tmlmobilidade/sae-controller-stream",
		"dev:sync-apex-t11": "turbo dev --filter=@tmlmobilidade/sae-controller-sync-apex-t11",
		"dev:sync-apex-t19": "turbo dev --filter=@tmlmobilidade/sae-controller-sync-apex-t19",
		"dev:sync-vehicle-events": "turbo dev --filter=@tmlmobilidade/sae-controller-sync-vehicle-events",
		"lint": "turbo lint"
	},
	"devDependencies": {
		"@carrismetropolitana/eslint": "20250303.2009.45",
		"@tmlmobilidade/tsconfig": "20241213.1919.54",
		"turbo": "2.4.4",
		"typescript": "5.8.2"
	},
	"workspaces": [
		"apps/bridge/*",
		"apps/engine/*",
		"apps/explorer/*",
		"packages/*"
	],
	"packageManager": "npm@11.1.0",
	"engines": {
		"node": ">=18"
	}
}
