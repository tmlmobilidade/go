{
	"name": "@tmlmobilidade/sae-stops",
	"private": true,
	"scripts": {
		"build": "turbo build",
		"dev": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev",
		"dev:parser": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@tmlmobilidade/sae-stops-parser",
		"dev:ui": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@tmlmobilidade/sae-stops-api --filter=@tmlmobilidade/sae-stops-frontend",
		"lint": "turbo lint",
		"rinse": "npx --yes @tmlmobilidade/repo-rinse",
		"start": "turbo start"
	},
	"devDependencies": {
		"@carrismetropolitana/eslint": "20250622.1204.50",
		"@dotenv-run/cli": "1.3.6",
		"turbo": "2.5.8",
		"typescript": "5.9.3"
	},
	"packageManager": "npm@11.6.2",
	"engines": {
		"node": ">=18"
	},
	"workspaces": [
		"apps/*"
	]
}
