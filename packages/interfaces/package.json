		"@go/types": "*",
		"@go/utils": "*",
		"bcryptjs": "3.0.3",
		"oci-common": "2.121.0",
		"oci-objectstorage": "2.121.0",
		"zod": "3.25.76"
	},
	"devDependencies": {
		"@carrismetropolitana/eslint": "20250622.1204.50",
