{
	"extends": "@tmlmobilidade/tsconfig/nextjs.json",
	"compilerOptions": {
		"paths": {
			"#/package.json": ["./package.json"],
			"@/*": ["./src/*"],
			"@assets/*": ["../../../../assets/*"]
		},
		"plugins": [
			{ "name": "next" }
		],
		"rootDir": ".",
		"types": ["node"]
	},
	"include": [
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		".next/types/**/*.ts"
	],
	"exclude": [
		"node_modules"
	]
}
