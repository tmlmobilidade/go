{
	"name": "@go/ui",
	"description": "UI components for Transportes Metropolitanos de Lisboa (TML) web applications.",
	"version": "1.0.0",
	"author": "João de Vasconcelos & Jusi Monteiro",
	"license": "AGPL-3.0-or-later",
	"publishConfig": {
		"access": "public",
		"directory": "dist"
	},
	"type": "module",
	"files": [
		"dist/"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./styles": {
			"default": "./dist/styles.css"
		},
		"./styles-no-reset": {
			"default": "./dist/styles-no-reset.css"
		}
	},
	"scripts": {
		"build": "npm run clean && tsx scripts/build.ts",
		"clean": "rm -rf dist",
		"dev": "tsx scripts/watch.ts",
		"lint": "eslint ./src && tsc --noEmit",
		"lint:fix": "eslint ./src --fix"
	},
	"peerDependencies": {
		"next": "15.x",
		"react": "19.x",
		"react-dom": "19.x",
		"swr": "2.x"
	},
	"browser": {
		"fs": false,
		"os": false,
		"path": false
	},
	"dependencies": {
		"@carrismetropolitana/api-types": "20251021.1634.49",
		"@go/lib": "*",
		"@go/types": "*",
		"@go/utils": "*",
		"@mantine/charts": "8.3.5",
		"@mantine/core": "8.3.5",
		"@mantine/dates": "8.3.5",
		"@mantine/form": "8.3.5",
		"@mantine/hooks": "8.3.5",
		"@mantine/modals": "8.3.5",
		"@mantine/notifications": "8.3.5",
		"@tabler/icons-react": "3.35.0",
		"@vis.gl/react-maplibre": "8.1.0",
		"clsx": "2.1.1",
		"luxon": "3.7.2",
		"mantine-form-zod-resolver": "1.3.0",
		"maplibre-gl": "5.10.0",
		"react-viewport-list": "7.1.2",
		"ukkonen": "2.2.0"
	},
	"devDependencies": {
		"@rollup/plugin-commonjs": "28.0.8",
		"@rollup/plugin-node-resolve": "16.0.3",
		"@rollup/plugin-typescript": "12.1.4",
		"@turf/turf": "7.2.0",
		"@types/geojson": "7946.0.16",
		"@types/luxon": "3.7.1",
		"@types/node": "24.9.1",
		"@types/react": "19.1.1",
		"@types/react-dom": "19.1.1",
		"nodemon": "3.1.10",
		"postcss": "8.5.6",
		"rollup": "4.45.1",
		"rollup-plugin-dts": "6.2.3",
		"rollup-plugin-postcss": "4.0.2",
		"rollup-plugin-tsconfig-paths": "1.5.2",
		"rollup-preserve-directives": "1.1.3",
		"swr": "2.3.6",
		"tsx": "4.20.6",
		"typescript": "5.9.3"
	}
}
