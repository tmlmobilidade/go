# Terraform provider cache and plugins
.terraform/
.terraform.lock.hcl

# State files (contain sensitive output values)
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Variable files with secrets — copy from terraform.tfvars.hcl.example
*.tfvars
*.tfvars.hcl

# Crash log files
crash.log
crash.*.log

# Override files (local dev use only)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plan files may contain sensitive data
*.tfplan
