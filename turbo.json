{
	"$schema": "https://turbo.build/schema.json",
	"concurrency": "100",
	"envMode": "loose",
	"globalEnv": [
		"NODE_ENV"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"lint": {},
		"lint:fix": {},
		"watch": {
			"outputs": ["dist/**"],
			"persistent": true
		}
	},
	"ui": "tui"
}
