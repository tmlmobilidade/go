{
	"name": "@tmlmobilidade/sae-performance",
	"private": true,
	"scripts": {
		"build": "turbo build",
		"build:sync-metrics": "dotenv-run -f ./environments/development/secrets/.env -- turbo build --filter=@tmlmobilidade/sae-performance-sync-metrics",
		"clean": "npx @tmlmobilidade/repo-rinse",
		"dev": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev",
		"dev:sync-metrics": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@tmlmobilidade/sae-performance-sync-metrics",
		"lint": "turbo lint",
		"start": "turbo start"
	},
	"devDependencies": {
		"@carrismetropolitana/eslint": "20250622.1204.50",
		"@dotenv-run/cli": "1.3.6",
		"@types/luxon": "^3.7.1",
		"turbo": "2.5.8",
		"typescript": "5.9.3"
	},
	"packageManager": "npm@11.6.2",
	"engines": {
		"node": ">=18"
	},
	"workspaces": [
		"apps/*"
	],
	"dependencies": {
		"@helperkits/logger": "^20250628.901.58",
		"@helperkits/timer": "^20240627.34.23",
		"@tmlmobilidade/interfaces": "20251009.1648.44",
		"@tmlmobilidade/utils": "20251009.1648.44",
		"npm-check-updates": "^19.0.0",
		"p-limit": "^7.1.1"
	}
}
