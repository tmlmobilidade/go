{

	"[css]": {
		"editor.codeActionsOnSave": {
			"source.fixAll.stylelint": "explicit"
		},
		"editor.defaultFormatter": "vscode.css-language-features"
	},

	"[typescriptreact]": {
		"editor.defaultFormatter": "vscode.typescript-language-features"
	},
	// Disable the default CSS formatter, use stylelint instead
	"css.validate": false,

	// Auto fix
	"editor.codeActionsOnSave": {
		"source.fixAll.eslint": "explicit"
	},

	"editor.defaultFormatter": "dbaeumer.vscode-eslint",
	"editor.formatOnSave": false,
	"editor.tabSize": 4,

	"eslint.format.enable": true,
	// Enable eslint for all supported languages
	"eslint.validate": [
		"javascript",
		"javascriptreact",
		"typescript",
		"typescriptreact",
		"vue",
		"html",
		"markdown",
		"json",
		"jsonc",
		"yaml",
		"toml",
		"astro"
	],
	"eslint.workingDirectories": [{ "mode": "auto" }],
	"files.eol": "\n",

	"github.copilot.chat.commitMessageGeneration.instructions": [
		{
			"text": "Follow the TML conventional commit format exactly: type(scope): description. Types: feat, fix, refactor, perf, test, docs, chore, ci, style, revert, wip. Subject must be lowercase, imperative mood, max 72 characters, no trailing period. Add a blank line before body or footer if present. Never invent scopes — use only scopes defined in the repo's commitlint.config.cjs."
		}
	],

	"less.validate": false,
	// Disable the default formatter, use eslint instead
	"prettier.enable": false,
	"scss.validate": false,

	"svg.preview.background": "custom",
	"workbench.editor.customLabels.enabled": true,

	"workbench.editor.customLabels.patterns": {
		"**/*.tsx": "${dirname} (${extname})",
		"**/components/**/*.css": "${dirname} (${extname})",
		"**/components/**/*.js": "${dirname} (${extname})"
	}

}
