	},
	"dependencies": {
		"@clack/core": "0.5.0",
		"@clack/prompts": "0.11.0",
		"@go/consts": "*",
		"@go/types": "*",
		"chalk": "5.6.2",
		"npm-check-updates": "19.1.2"
	},
	"devDependencies": {
		"@go/tsconfig": "*",
		"@types/node": "24.10.0",
		"resolve-tspaths": "0.8.23",
		"tsx": "4.20.6"
	}
}
