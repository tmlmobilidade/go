{
	"name": "@tmlmobilidade/sae-controller",
	"private": true,
	"scripts": {
		"build:bridge": "turbo build --filter=@tmlmobilidade/sae-controller-bridge-*",
		"build:engine": "turbo build --filter=@tmlmobilidade/sae-controller-engine-*",
		"build:explorer": "turbo build --filter=@tmlmobilidade/sae-controller-explorer-*",
		"clean": "sh cleanup.sh",
		"dev:bridge": "turbo dev --filter=@tmlmobilidade/sae-controller-bridge-*",
		"dev:engine": "turbo dev --filter=@tmlmobilidade/sae-controller-engine-*",
		"dev:engine-coordinator": "turbo dev --filter=@tmlmobilidade/sae-controller-engine-coordinator",
		"dev:engine-examiner": "turbo dev --filter=@tmlmobilidade/sae-controller-engine-examiner",
		"dev:explorer": "turbo dev --filter=@tmlmobilidade/sae-controller-explorer-*",
		"lint": "turbo lint"
	},
	"devDependencies": {
		"@carrismetropolitana/eslint": "20250325.1926.5",
		"@tmlmobilidade/tsconfig": "20250325.1731.13",
		"turbo": "2.5.0",
		"typescript": "5.8.3"
	},
	"workspaces": [
		"apps/bridge/*",
		"apps/engine/*",
		"apps/explorer/*",
		"packages/*"
	],
	"packageManager": "npm@11.2.0",
	"engines": {
		"node": ">=18"
	}
}
