{
	"name": "@tmlmobilidade/sae-replicator",
	"private": true,
	"scripts": {
		"build": "turbo build",
		"build:enrich": "turbo build --filter=@tmlmobilidade/sae-replicator-enrich",
		"build:packages": "turbo build --filter=@tmlmobilidade/sae-replicator-pckg-*",
		"build:stream": "turbo build --filter=@tmlmobilidade/sae-replicator-stream",
		"clean": "sh cleanup.sh",
		"dev:enrich": "turbo dev --filter=@tmlmobilidade/sae-replicator-enrich",
		"dev:stream": "turbo dev --filter=@tmlmobilidade/sae-replicator-stream",
		"dev:sync-apex-on-board-sales": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@tmlmobilidade/sae-replicator-sync-apex-on-board-sales",
		"dev:sync-apex-validations": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@tmlmobilidade/sae-replicator-sync-apex-validations",
		"lint": "turbo lint"
	},
	"devDependencies": {
		"@carrismetropolitana/eslint": "20250418.42.41",
		"@dotenv-run/cli": "1.3.6",
		"turbo": "2.5.3",
		"typescript": "5.8.3"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"packageManager": "npm@11.4.1",
	"engines": {
		"node": ">=18"
	}
}
