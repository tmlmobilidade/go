{
	"name": "@tmlmobilidade/emails",
	"version": "1.0.0",
	"author": {
		"email": "iso@tmlmobilidade.com",
		"name": "TML-ISO"
	},
	"license": "AGPL-3.0-or-later",
	"homepage": "https://github.com/tmlmobilidade/services#readme",
	"bugs": {
		"url": "https://github.com/tmlmobilidade/services/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tmlmobilidade/services.git"
	},
	"keywords": [
		"public transit",
		"tml",
		"transportes metropolitanos de lisboa",
		"services"
	],
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"files": [
		"dist/"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc && resolve-tspaths",
		"build:watch": "tsc-watch --onSuccess 'resolve-tspaths'",
		"dev2": "email dev -p 3001 --dir ./src/emails",
		"export": "email export --dir ./src/emails",
		"lint": "eslint ./src/ && tsc --noEmit"
	},
	"dependencies": {
		"@tmlmobilidade/utils": "*",
		"@react-email/components": "0.5.7",
		"@types/nodemailer": "7.0.3",
		"browserslist": "4.27.0",
		"nodemailer": "7.0.10",
		"react": "19.2.0",
		"react-email": "4.3.2"
	},
	"devDependencies": {
		"@carrismetropolitana/eslint": "20250622.1204.50",
		"@tmlmobilidade/consts": "*",
		"@tmlmobilidade/tsconfig": "*",
		"@tmlmobilidade/types": "*",
		"@tmlmobilidade/utils": "*",
		"@react-email/preview-server": "4.3.2",
		"@types/node": "24.10.0",
		"resolve-tspaths": "0.8.23",
		"tsc-watch": "7.2.0",
		"typescript": "5.9.3"
	}
}
