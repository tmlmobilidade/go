{
	"name": "@tmlmobilidade/sae-controller",
	"private": true,
	"scripts": {
		"build": "turbo build",
		"clean": "sh cleanup.sh",
		"dev:bridge": "turbo dev --filter=@tmlmobilidade/sae-controller-bridge-*",
		"dev:engine": "turbo dev --filter=@tmlmobilidade/sae-controller-engine-*",
		"dev:explorer": "turbo dev --filter=@tmlmobilidade/sae-controller-explorer-*",
		"lint": "turbo lint"
	},
	"devDependencies": {
		"@carrismetropolitana/eslint": "20250303.2009.45",
		"@tmlmobilidade/tsconfig": "20241213.1919.54",
		"turbo": "2.4.4",
		"typescript": "5.8.2"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"packageManager": "npm@11.1.0",
	"engines": {
		"node": ">=18"
	}
}
