{
	"name": "@tmlmobilidade/sae-controller",
	"private": true,
	"scripts": {
		"build:bridge": "turbo build --filter=@tmlmobilidade/sae-controller-bridge-*",
		"build:engine": "turbo build --filter=@tmlmobilidade/sae-controller-engine-*",
		"build:explorer": "turbo build --filter=@tmlmobilidade/sae-controller-explorer-*",
		"build:packages": "turbo build --filter=@tmlmobilidade/sae-controller-pckg-*",
		"clean": "sh cleanup.sh",
		"dev:bridge": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@tmlmobilidade/sae-controller-bridge-*",
		"dev:engine": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@tmlmobilidade/sae-controller-engine-*",
		"dev:engine-coordinator": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@tmlmobilidade/sae-controller-engine-coordinator",
		"dev:engine-examiner": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@tmlmobilidade/sae-controller-engine-examiner",
		"dev:engine-feeder": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@tmlmobilidade/sae-controller-engine-feeder",
		"dev:explorer": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@tmlmobilidade/sae-controller-explorer-*",
		"lint": "turbo lint"
	},
	"devDependencies": {
		"@carrismetropolitana/eslint": "20250418.42.41",
		"@tmlmobilidade/tsconfig": "20250531.2332.25",
		"turbo": "2.5.4",
		"typescript": "5.8.3"
	},
	"workspaces": [
		"apps/bridge/*",
		"apps/engine/*",
		"apps/explorer/*",
		"packages/*"
	],
	"packageManager": "npm@11.4.1",
	"engines": {
		"node": ">=18"
	}
}
