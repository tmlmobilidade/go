{
	"name": "@tmlmobilidade/go",
	"author": {
		"email": "iso@tmlmobilidade.pt",
		"name": "TML-ISO"
	},
	"license": "AGPL-3.0-or-later",
	"main": "./dist/index.js",
	"scripts": {
		"build": "turbo build",
		"build:alerts": "ENVIRONMENT=development dotenv-run -f ./modules/alerts/environments/staging/secrets/.env -- turbo run build --filter=@tmlmobilidade/go-alerts-*",
		"build:alerts:packages": "ENVIRONMENT=development dotenv-run -f ./modules/alerts/environments/staging/secrets/.env -- turbo run build --filter=@tmlmobilidade/go-alerts-pckg-*",
		"build:auth": "ENVIRONMENT=development dotenv-run -f ./modules/auth/environments/staging/secrets/.env -- turbo run build --filter=@tmlmobilidade/go-auth-*",
		"build:controller": "ENVIRONMENT=development dotenv-run -f ./modules/controller/environments/staging/secrets/.env -- turbo run build --filter=@tmlmobilidade/go-controller-*",
		"build:dates": "ENVIRONMENT=development dotenv-run -f ./modules/dates/environments/staging/secrets/.env -- turbo run build --filter=@tmlmobilidade/go-dates-*",
		"build:exporter": "ENVIRONMENT=development dotenv-run -f ./modules/exporter/environments/staging/secrets/.env -- turbo run build --filter=@tmlmobilidade/go-exporter-*",
		"build:locations": "ENVIRONMENT=development dotenv-run -f ./modules/locations/environments/staging/secrets/.env -- turbo run build --filter=@tmlmobilidade/go-locations-*",
		"build:modules": "turbo build --filter=./modules/**/*",
		"build:offer": "ENVIRONMENT=development dotenv-run -f ./modules/offer/environments/staging/secrets/.env -- turbo run build --filter=@tmlmobilidade/go-offer-*",
		"build:packages": "turbo build --filter=./packages/**/* && npm run generate-routes",
		"build:performance": "ENVIRONMENT=development dotenv-run -f ./modules/performance/environments/staging/secrets/.env -- turbo run build --filter=@tmlmobilidade/go-performance-*",
		"build:plans": "ENVIRONMENT=development dotenv-run -f ./modules/plans/environments/staging/secrets/.env -- turbo run build --filter=@tmlmobilidade/go-plans-*",
		"build:replicator": "ENVIRONMENT=development dotenv-run -f ./modules/replicator/environments/staging/secrets/.env -- turbo run build --filter=@tmlmobilidade/go-replicator-*",
		"build:stops": "ENVIRONMENT=development dotenv-run -f ./modules/stops/environments/staging/secrets/.env -- turbo run build --filter=@tmlmobilidade/go-stops-*",
		"build:ticketing": "ENVIRONMENT=development dotenv-run -f ./modules/ticketing/environments/staging/secrets/.env -- turbo run build --filter=@tmlmobilidade/go-ticketing-*",
		"build:types": "turbo build --filter=@tmlmobilidade/types",
		"dev:alerts": "ENVIRONMENT=development dotenv-run -f ./modules/alerts/environments/staging/secrets/.env -- turbo run dev --filter=@tmlmobilidade/go-alerts-*",
		"dev:auth": "ENVIRONMENT=development dotenv-run -f ./modules/auth/environments/staging/secrets/.env -- turbo run dev --filter=@tmlmobilidade/go-auth-*",
		"dev:auth:prod": "ENVIRONMENT=development dotenv-run -f ./modules/auth/environments/production/secrets/.env -- turbo run dev --filter=@tmlmobilidade/go-auth-*",
		"dev:controller": "ENVIRONMENT=development dotenv-run -f ./modules/controller/environments/staging/secrets/.env -- turbo run dev --filter=@tmlmobilidade/go-controller-*",
		"dev:controller:prod": "ENVIRONMENT=development dotenv-run -f ./modules/controller/environments/production/secrets/.env -- turbo run dev --filter=@tmlmobilidade/go-controller-*",
		"dev:controller:ui": "ENVIRONMENT=development dotenv-run -f ./modules/controller/environments/staging/secrets/.env -- turbo run dev --filter=@tmlmobilidade/go-controller-api --filter=@tmlmobilidade/go-controller-frontend",
		"dev:dates": "ENVIRONMENT=development dotenv-run -f ./modules/dates/environments/staging/secrets/.env -- turbo run dev --filter=@tmlmobilidade/go-dates-*",
		"dev:fleet": "ENVIRONMENT=development dotenv-run -f ./modules/fleet/environments/staging/secrets/.env -- turbo run dev --filter=@tmlmobilidade/go-fleet-*",
		"dev:exporter": "ENVIRONMENT=development dotenv-run -f ./modules/exporter/environments/staging/secrets/.env -- turbo run dev --filter=@tmlmobilidade/go-exporter-*",
		"dev:exporter-merged": "ENVIRONMENT=development dotenv-run -f ./modules/exporter/environments/staging/secrets/.env -- turbo run dev --filter=@tmlmobilidade/go-exporter-export-gtfs-merged",
		"dev:fleet": "ENVIRONMENT=development dotenv-run -f ./modules/fleet/environments/staging/secrets/.env -- turbo run dev --filter=@tmlmobilidade/go-fleet-*",
		"dev:locations": "ENVIRONMENT=development dotenv-run -f ./modules/locations/environments/staging/secrets/.env -- turbo run dev --filter=@tmlmobilidade/go-locations-*",
		"dev:offer": "ENVIRONMENT=development dotenv-run -f ./modules/offer/environments/staging/secrets/.env -- turbo run dev --filter=@tmlmobilidade/go-offer-*",
		"dev:performance": "ENVIRONMENT=development dotenv-run -f ./modules/performance/environments/staging/secrets/.env -- turbo run dev --filter=@tmlmobilidade/go-performance-*",
		"dev:plans": "ENVIRONMENT=development dotenv-run -f ./modules/plans/environments/staging/secrets/.env -- turbo run dev --filter=@tmlmobilidade/go-plans-*",
		"dev:replicator": "ENVIRONMENT=development dotenv-run -f ./modules/replicator/environments/staging/secrets/.env -- turbo run dev --filter=@tmlmobilidade/go-replicator-*",
		"dev:replicator:helpers-dump-data": "ENVIRONMENT=development dotenv-run -f ./modules/replicator/environments/staging/secrets/.env -- turbo run dev --filter=@tmlmobilidade/go-replicator-helpers-dump-data",
		"dev:stops": "ENVIRONMENT=development dotenv-run -f ./modules/stops/environments/staging/secrets/.env -- turbo run dev --filter=@tmlmobilidade/go-stops-*",
		"dev:stops:ui": "ENVIRONMENT=development dotenv-run -f ./modules/stops/environments/staging/secrets/.env -- turbo run dev --filter=@tmlmobilidade/go-stops-api --filter=@tmlmobilidade/go-stops-frontend",
		"dev:ticketing": "ENVIRONMENT=development dotenv-run -f ./modules/ticketing/environments/staging/secrets/.env -- turbo run dev --filter=@tmlmobilidade/go-ticketing-*",
		"generate-routes": "bash ./scripts/generate-routes.sh && turbo lint:fix --filter=@tmlmobilidade/consts",
		"helper:alerts:migrate-db": "dotenv-run -f ./modules/alerts/environments/staging/secrets/.env -- turbo run start --filter=@tmlmobilidade/go-alerts-helpers-migrate-db",
		"helper:controller:export-sams:production": "dotenv-run -f ./modules/controller/environments/production/secrets/.env -- turbo run start --filter=@tmlmobilidade/go-controller-helpers-export-sams",
		"helper:locations:seed-locations:production": "dotenv-run -f ./modules/locations/environments/production/secrets/.env -- turbo run start --filter=@tmlmobilidade/go-locations-helpers-seed-locations",
		"helper:locations:seed-locations:staging": "dotenv-run -f ./modules/locations/environments/staging/secrets/.env -- turbo run start --filter=@tmlmobilidade/go-locations-helpers-seed-locations",
		"helper:stops:seed-stops": "dotenv-run -f ./modules/stops/environments/staging/secrets/.env -- turbo run start --filter=@tmlmobilidade/go-stops-helpers-seed-stops",
		"lint": "turbo lint",
		"lint:fix": "turbo lint:fix",
		"rinse": "npx --yes @tmlmobilidade/repo-rinse",
		"watch:packages": "npm run build:packages && turbo run watch --filter=./packages/**/*"
	},
	"devDependencies": {
		"@carrismetropolitana/eslint": "20250622.1204.50",
		"@dotenv-run/cli": "1.3.6",
		"turbo": "2.7.3"
	},
	"packageManager": "npm@11.7.0",
	"workspaces": [
		"!**/.next",
		"modules/**/*",
		"packages/**/*",
		"cli/*"
	]
}
