{
	"$schema": "https://turbo.build/schema.json",
	"concurrency": "12",
	"envMode": "loose",
	"globalEnv": [
		"NODE_ENV"
	],
	"tasks": {
		"build": {
			"dependsOn": [
				"^build"
			],
			"outputs": [
				"dist/**"
			]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"lint": {},
		"lint:fix": {},
		"start": {
			"cache": false,
			"persistent": true
		},
		"watch": {
			"outputs": [
				"dist/**"
			],
			"persistent": true
		}
	},
	"ui": "tui"
}
