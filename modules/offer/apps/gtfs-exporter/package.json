{
	"name": "@tmlmobilidade/go-offer-gtfs-exporter",
	"version": "1.0.0",
	"author": {
		"email": "iso@tmlmobilidade.pt",
		"name": "TML-ISO"
	},
	"license": "AGPL-3.0-or-later",
	"type": "module",
	"files": [
		"dist"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsc && resolve-tspaths",
		"dev": "ENVIRONMENT=development dotenv-run -f ./modules/offer/environments/production/secrets/.env tsx watch src/index.ts",
		"dev:local": "ENVIRONMENT=development dotenv-run -f ./modules/offer/environments/production/secrets/.env tsx src/local.ts",
		"lint": "eslint ./src && tsc --noEmit",
		"lint:fix": "eslint --fix .",
		"rules:overlaps": "dotenv-run -f ../../environments/staging/secrets/.env -- tsx src/scripts/vkm-export-alignment/scan-overlapping-timepoints.ts",
		"vkm:check": "dotenv-run -f ../../environments/staging/secrets/.env -- tsx src/scripts/vkm-export-alignment/compare-vkm-summary.ts",
		"vkm:dates": "dotenv-run -f ../../environments/staging/secrets/.env -- tsx src/scripts/vkm-export-alignment/compare-circulation-dates.ts"
	},
	"dependencies": {
		"@tmlmobilidade/consts": "*",
		"@tmlmobilidade/dates": "*",
		"@tmlmobilidade/fastify": "*",
		"@tmlmobilidade/files": "*",
		"@tmlmobilidade/interfaces": "*",
		"@tmlmobilidade/logger": "*",
		"@tmlmobilidade/rabbitmq": "*",
		"@tmlmobilidade/strings": "*",
		"@tmlmobilidade/types": "*",
		"@tmlmobilidade/utils": "*",
		"@tmlmobilidade/writers": "*",
		"adm-zip": "0.5.17",
		"formidable": "3.5.4",
		"papaparse": "5.5.3"
	},
	"devDependencies": {
		"@tmlmobilidade/tsconfig": "*",
		"@types/adm-zip": "0.5.8",
		"@types/node": "25.9.3",
		"@types/papaparse": "5.5.2",
		"resolve-tspaths": "0.8.23",
		"tsx": "4.22.4",
		"typescript": "6.0.3"
	}
}
