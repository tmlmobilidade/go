{
	"name": "go",
	"author": {
		"email": "iso@tmlmobilidade.com",
		"name": "TML-ISO"
	},
	"license": "AGPL-3.0-or-later",
	"main": "index.js",
	"scripts": {
		"build": "turbo build",
		"build:packages": "turbo build --filter=./packages/**/*",
		"build:types": "turbo build --filter=@go/types",
		"dev": "turbo dev",
		"dev:alerts": "dotenv-run -f ./modules/alerts/environments/development/secrets/.env -- turbo run dev --filter=@go/alerts-*...",
		"dev:packages": "turbo dev --filter=./packages/**/*",
		"dev:test": "turbo run build:watch",
		"dev:types": "turbo dev --filter=@go/types",
		"lint": "turbo lint",
		"lint:fix": "turbo lint:fix",
		"rinse": "npx --yes @tmlmobilidade/repo-rinse"
	},
	"devDependencies": {
		"@carrismetropolitana/eslint": "20250622.1204.50",
		"@dotenv-run/cli": "1.3.6",
		"turbo": "2.6.0"
	},
	"packageManager": "npm@11.6.2",
	"workspaces": [
		"modules/**/*",
		"packages/**/*",
		"cli/*"
	]
}
