{
	"name": "create-tml-app",
	"description": "CLI tool to create new SAE applications.",
	"version": "1.0.0",
	"author": {
		"email": "iso@tmlmobilidade.com",
		"name": "TML-ISO"
	},
	"license": "AGPL-3.0-or-later",
	"keywords": [
		"tml",
		"tmlmobilidade",
		"create-tml-app",
		"carrismetropolitana"
	],
	"type": "module",
	"files": [
		"dist",
		"template",
		"README.md",
		"LICENSE",
		"CHANGELOG.md",
		"package.json"
	],
	"main": "dist/index.js",
	"exports": {
		".": "./dist/index.js"
	},
	"bin": {
		"create-tml-app": "./dist/index.js"
	},
	"scripts": {
		"build": "tsc && resolve-tspaths",
